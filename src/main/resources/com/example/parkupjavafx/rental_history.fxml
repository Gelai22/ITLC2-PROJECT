<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" styleClass="bg-light" stylesheets="@css/application.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.parkupjavafx.controllers.RentalHistoryController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox style="-fx-background-color: #e1f5fa; -fx-background-radius: 10; -fx-padding: 20;">
        <Label text="Completed Rental History" textFill="#0085db">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <Label text="Review your past vehicle rental transactions." styleClass="text-muted" />
    </VBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="idCol" text="#" prefWidth="60.0" />
                <TableColumn fx:id="vehicleCol" text="Vehicle" prefWidth="200.0" />
                <TableColumn fx:id="periodCol" text="Rental Period" prefWidth="100.0" />
                <TableColumn fx:id="returnCol" text="Return Date" prefWidth="120.0" />
                <TableColumn fx:id="costCol" text="Final Cost" prefWidth="100.0" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120.0" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>